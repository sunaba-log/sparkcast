# Copy this file to .env.local for local development.
# Do not commit .env.local or real secret values.
# See docs/runbooks/environment-variables.md for where to obtain each value.

# Local PostgreSQL can use DATABASE_URL. The deployed app (Cloud Run) uses the
# Cloud SQL Connector settings below instead.
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/podcast
CLOUD_SQL_INSTANCE_CONNECTION_NAME=sunabalog-dev:asia-northeast1:podcast-automator-postgres-dev
DB_NAME=podcast
DB_USER=podcast_app
DB_PASSWORD=

GOOGLE_CLOUD_PROJECT=sunabalog-dev
# Optional. Comma-separated login allowlist. Unset or empty allows all accounts.
DEV_ALLOWED_EMAILS=developer@example.com

GCS_UPLOAD_BUCKET=podcast-automator-audio-input-dev
GCS_SIGNED_URL_TTL_SECONDS=900

# Required outside Google Cloud. JSON for a service account that can access
# Firebase Auth, Firestore, and signed GCS uploads.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase Web SDK settings used by the login screen.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sunabalog-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sunabalog-dev
# Optional. Defaults to ${NEXT_PUBLIC_FIREBASE_PROJECT_ID}.firebaseapp.com.
# 本番でモバイルのリダイレクトログインを使う場合、NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN を
# 配信ホストにしつつ、これは Firebase ヘルパーホストのままにする。
FIREBASE_AUTH_HELPER_DOMAIN=sunabalog-dev.firebaseapp.com

# Shared secret for scheduled cleanup endpoint.
CRON_SECRET=replace-with-a-random-secret
# 議事録チャット (Vertex AI / Gemini)。認証は FIREBASE_SERVICE_ACCOUNT_JSON と
# GOOGLE_CLOUD_PROJECT を流用する。以下は任意で既定値あり。
VERTEX_AI_LOCATION=global
VERTEX_AI_MODEL=gemini-2.5-flash
# RAG 横断検索用の埋め込みモデル（Firestore ベクトル検索に保存）。
VERTEX_AI_EMBEDDING_MODEL=text-multilingual-embedding-002

# ユーザー承認・利用制限設定
# 管理者メールアドレス（カンマ区切り）
ADMIN_EMAILS=admin@sunabalog.com
# 未事前登録ユーザ向けに表示する問い合わせ先メールアドレス
CONTACT_EMAIL=admin@sunabalog.com
# 承認待ちユーザーの AI チャット上限（累計回数）
PENDING_CHAT_LIMIT=5
# 承認待ちユーザーのエピソードアップロード上限（累計回数）
PENDING_EPISODE_UPLOAD_LIMIT=2
# 承認済みユーザーの AI チャット時間制限（1時間あたりの回数）
RATE_LIMIT_HOURLY=20
# 承認済みユーザーの AI チャット日次制限（1日あたりの回数）
RATE_LIMIT_DAILY=100
