# -------------------------------------------------
# Podcast Processing Job (entrypoints.main)
# -------------------------------------------------
PROJECT_ID=your-gcp-project-id
GCS_BUCKET=your-input-bucket-name
GCS_TRIGGER_OBJECT_NAME=path/to/input/file.m4a
R2_BUCKET=your-r2-bucket-name

# Either set SECRET_NAME, or set both CLOUDFLARE_* keys directly.
SECRET_NAME=podcast-automator
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
R2_ENDPOINT_URL=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=

R2_KEY_PREFIX=test
R2_CUSTOM_DOMAIN=podcast.example.com
AI_MODEL_ID=gemini-2.5-flash
DISCORD_WEBHOOK_INFO_URL=https://discord.example/webhook/info

# -------------------------------------------------
# Weekly Agenda Job (entrypoints.agenda_main)
# -------------------------------------------------
DISCORD_WEBHOOK_AGENDA_URL=https://discord.example/webhook/agenda
DISCORD_BOT_TOKEN=
DISCORD_TRANSCRIPT_CHANNEL_ID=
TRANSCRIPT_FETCH_LIMIT=50
DEBUG_JSON_PATH=
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
